{
  "name": "neko-ai",
  "displayName": "neko-ai",
  "description": "AI assistant helping you to learn to code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.113.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Neko AI",
      "properties": {
        "neko-ai.language": {
          "type": "string",
          "enum": [
            "Lithuanian",
            "English",
            "Polish"
          ],
          "default": "Lithuanian",
          "description": "The language Neko AI will use to speak to you."
        },
        "neko-ai.aiProvider": {
          "type": "string",
          "enum": [
            "Ollama",
            "Google AI Studio"
          ],
          "default": "Ollama",
          "description": "The AI provider you want to use."
        },
        "neko-ai.googleApiKey": {
          "type": "string",
          "default": "",
          "description": "Your Google AI Studio API key.",
          "secret": true
        },
        "neko-ai.googleModel": {
          "type": "string",
          "default": "gemini-2.5-flash",
          "description": "The Google AI Studio model to use (e.g. gemini-2.5-flash or gemini-2.0-flash)."
        },
        "neko-ai.debugMode": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging in the Neko AI webview window."
        }
      }
    },
    "commands": [
      {
        "command": "neko-ai.explainTask",
        "title": "NekoAI: Explain the Task"
      },
      {
        "command": "neko-ai.showExample",
        "title": "NekoAI: Show me an Example"
      },
      {
        "command": "neko-ai.explainError",
        "title": "NekoAI: Explain Error"
      },
      {
        "command": "neko-ai.explainCode",
        "title": "NekoAI: Explain my Code"
      },
      {
        "command": "neko-ai.open",
        "title": "NekoAI: Open Panel"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "neko-ai.explainCode",
          "when": "editorHasSelection"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.115.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
